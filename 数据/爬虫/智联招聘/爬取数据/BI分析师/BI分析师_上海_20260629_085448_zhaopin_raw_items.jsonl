tureServer": null, "imSection": null, "internship": [], "live": {"liveItems": [], "liveQuickFocusChecked": 0, "liveQuickFocusState": 0, "recommendLiveList": [], "state": 0}, "operationSection": {"topJobBannerArea": null}, "partTime": [], "position": {"base": {"deliveryPath": "", "education": "本科", "educationCode": "", "maxSalary": "", "minSalary": "", "positionId": 40809379502, "positionName": "bi数据分析师", "positionNumber": "CC848290930J40809379502", "positionUrl": "", "positionWorkingExp": "3-5年", "positionWorkingExpCode": "", "propertyType": "", "recruitNumber": 1, "salary": "1.4-1.6万·13薪", "salaryReal": "", "workType": "全职"}, "date": {"dateEnd": "", "dateStart": "", "firstPublishTime": "", "positionPublishTime": "", "positionUpdateTime": "", "positionUpdateTimeText": ""}, "desc": {"description": "业务数字分析及运营\nMain Tasks\n1. 梳理项目业务数据流向，运用相关工具进行数据读取与分析；\nSupport to analyze the flow of business process and required data, be able to utilize relevant tools for data extraction and analysis\n2. 收集并分析各类数据需求，挖掘数据潜在价值，设计数据分析及数据挖掘模型；\nCollect and analyze massive amounts of data, uncover potential value in data assets, and design models for data analysis and data mining.\n3. 协调项目各部门高效完成数据整理及分析利用工作，并及时为相关方提供支持；\nCollaborate with cross-functional teams to efficiently organize and leverage data, providing timely support to stakeholders\n4. 使用 Power BI 工具对数据进行直观、明晰的可视化展示；\nUse Power BI to create clear and intuitive data visualizations\n5. 负责客户主数据的日常管理，包括数据校对、审批及部门间协调等工作；\nManage customer master data on daily basis, including data validation, approval processes, and interdepartmental coordination\n6. 负责CRM系统落地项目的日常项目协调工作，包括需求汇总、功能测试及用户培训；\nSupport daily coordination work of CRM system, include demand summary, new function test and user training;\n7. 完成上级或部门安排的其他日常项目支持事务。\nSupport other routine project tasks assigned by supervisors or the department\nMinimum Education and Qualification Required for the Position\n1. 3年以上数据分析与建模经验，本科以上学历，计算机科学、统计学、商科等；\nMinimum of 3 years’ experience in data analysis and modeling, with a Bachelor’s degree or above in Computer Science, Statistics, Business, or related fields\n2. 熟悉使用数据分析和可视化工具软件，Power BI，Excel等\nProficient in data analysis and visualization tools such as Power BI and Excel\n3. 熟悉使用SQL语言，对主流数据库查询和计算处理；\nSkilled in SQL, with hands-on experience in querying and processing data from mainstream databases\n4. 良好的数据敏感度，能够从海量数据中提炼核心需求结果；\nStrong data intuition, capable of extracting key insights from large and complex datasets\n5. 有产品开发项目经验者优先；\nPrior experience in product development projects is a plus\n6. 英语要求读写熟练；听说流利者或有外企经验者优先考虑。", "descriptionHighlight": "", "highlightLabels": [], "labels": ["SQL", "Python", "数据可视化", "数据挖掘", "数据清洗", "Power BI", "excel", "产业互联网平台", "软件/IT服务", "计算机软件"], "performanceBonus": "", "welfareLabel": [], "welfareTags": []}, "jobType": {"jobType": "", "jobTypeLevel": "9000400000000", "jobTypeLevelName": "", "subJobType": "", "subJobTypeLevel": "9000400010000", "subJobTypeLevelName": ""}, "onlineCarHailingExtend": {"gray": false, "promiseGuarantee": ""}, "onlineCarInfo": [], "other": {"customJobGroup": "DEFAULT", "deliveredPreviouslyTip": "", "jobKeyword": {"keywords": []}, "jobSkillTags": [], "jobTypeIsBlueCollar": false, "overseasList": [], "pageStyle": 0, "positionCommercialLabel": [], "positionHighlight": "", "propertyTypeUrl": "", "rpoProxyDisplayOrgName": "", "urgentRecruitmentUrl": ""}, "preferredHrInfo": {"icon": "", "introduce": "", "jumpUrl": "", "preferredHr": false}, "todayInterview": null, "workLocation": {"address": "工作地点：浦东新区 · 高桥", "addressType": 0, "latitude": "31.348091739259086", "longitude": "121.54099313464938", "positionCityDistrict": "", "positionCityDistrictCode": "", "positionCityId": "538", "positionWorkCity": "", "showMap": true, "showMultiAddressesTip": "", "staticMapUrl": "https://storage-public.zhaopin.cn/job/share/1756889317028825485/61b3d4aac63542a58304b58fe90c0957", "streetName": "", "tradingArea": "", "travelMode": "bus", "verifyTheTruthUrl": "",