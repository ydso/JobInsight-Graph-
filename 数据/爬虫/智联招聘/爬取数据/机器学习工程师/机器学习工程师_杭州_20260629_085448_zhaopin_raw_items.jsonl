eatureServer": null, "imSection": null, "internship": [], "live": {"liveItems": [], "liveQuickFocusChecked": 0, "liveQuickFocusState": 0, "recommendLiveList": [], "state": 0}, "operationSection": {"topJobBannerArea": null}, "partTime": [], "position": {"base": {"deliveryPath": "", "education": "本科", "educationCode": "", "maxSalary": "", "minSalary": "", "positionId": 40914542012, "positionName": "环境数据分析与机器学习工程师", "positionNumber": "CC344652930J40914542012", "positionUrl": "", "positionWorkingExp": "经验不限", "positionWorkingExpCode": "", "propertyType": "", "recruitNumber": 0, "salary": "6000-7000元", "salaryReal": "", "workType": "全职"}, "date": {"dateEnd": "", "dateStart": "", "firstPublishTime": "", "positionPublishTime": "", "positionUpdateTime": "", "positionUpdateTimeText": "6月22日发布"}, "desc": {"description": "岗位职责：\n负责环境监测、污染源排放、气象、水质、空气质量、碳排放及企业环保运行等数据的采集、清洗、治理、统计分析与可视化。\n运用数学分析、数理统计、时间序列分析、回归分析、空间统计等方法，识别环境数据变化规律、异常波动及主要影响因素。\n建立空气质量、水环境质量、污染排放、设备运行等场景的数据分析模型，开展预测预警、异常识别、污染溯源和治理效果评估。\n结合业务需求，应用机器学习方法开展分类、回归、聚类、预测、异常检测等工作，持续优化模型效果和应用价值。\n建立数据质量控制、指标计算、模型验证和结果解释机制，保证分析结果可靠、可追溯。\n制作环境数据分析报告、专题研判报告和可视化仪表盘，为环保管理、项目实施和技术决策提供支持。\n配合环境工程、监测运维、产品研发及业务团队，将数据模型转化为可落地的分析工具或业务功能。\n任职要求：\n本科及以上学历，数学与应用数学、统计学、数据科学、计算数学、人工智能、环境科学与工程、计算机科学等相关专业。\n具备扎实的数学分析、概率论、数理统计、线性代数、优化方法等基础。\n熟悉常用统计分析方法，包括描述性统计、假设检验、相关性分析、回归分析、聚类分析、主成分分析、时间序列分析等。\n熟悉机器学习基本方法及适用场景，包括但不限于：线性回归、逻辑回归、岭回归、Lasso 回归\n决策树、随机森林、XGBoost、LightGBM\nK-Means、层次聚类、DBSCAN\nSVM、KNN、朴素贝叶斯\n异常检测、预测模型、特征工程、模型评估\n熟练使用 Python，能够使用 pandas、NumPy、scikit-learn、Matplotlib/Seaborn 等工具完成数据处理、建模、评估和可视化；熟悉 R、MATLAB、SQL 者优先。\n具备较强的数据清洗、特征构建、模型调参、交叉验证及结果解释能力，能够避免数据泄漏、过拟合等常见问题。\n具备良好的逻辑能力、沟通能力和报告撰写能力，能将复杂模型结果转化为业务人员可理解的结论。\n工作年限不限；应届毕业生需具备较好的课程基础，并有科研项目、数学建模竞赛、数据分析项目或机器学习实践经历。\n优先条件\n有空气质量、水环境、污染源排放、碳排放、气象、遥感或 GIS 数据分析经验。\n有时间序列预测经验，如 ARIMA、Prophet、LSTM、Transformer 等模型应用经验。\n有环境数据异常识别、污染预警、设备故障预警、污染溯源或排放预测项目经验。\n熟悉 SQL 数据库及数据仓库基本概念，能够处理较大规模数据。\n熟悉 Power BI、Tableau、FineBI 等可视化工具，能制作环境质量、污染排放、项目运行等管理看板。\n有论文发表、专利、数学建模竞赛、统计建模竞赛、机器学习竞赛或环保项目经验者优先。\n岗位能力重点：\n该岗位不是单纯制作统计报表，而是要求候选人能够从环境数据中发现问题、解释原因、建立预测或预警模型，并将分析结果转化为环保管理和治理工作可使用的建议。\n岗位适合人群：\n数学、统计、数据科学、人工智能专业应届毕业生；\n有数据分析、算法建模、环境监测或环保项目经验的人员；\n希望从传统数据分析向环境智能分析、预测预警和机器学习应用发展的人员", "descriptionHighlight": "", "highlightLabels": [], "labels": ["数据治理", "数据挖掘", "Python", "Matlab", "Pandas", "数据建模", "环保", "人工智能"], "performanceBonus": "", "welfareLabel": [], "welfareTags": []}, "jobType": {"jobType": "", "jobTypeLevel": "9000400000000", "jobTypeLevelName": "", "subJobType": "", "subJobTypeLevel": "9000400070000", "subJobTypeLevelName": ""}, "onlineCarHailingExtend": {"gray": false, "promiseGuarantee": ""}, "onlineCarInfo": [], "other": {"customJobGroup": "DEFAULT", "deliveredPreviouslyTip": "", "jobKeyword": {"keywords": []}, "jobSkillTags": [], "jobTypeIsBlueCollar": false, "overseasList": [], "pageStyle": 0, "positionCommercialLabel": [], "positionHighlight": "", "propertyTypeUrl": "", "rpoProxyDisplayOrgName": "", "urgentRecruitmentUrl": ""}, "preferredHrInfo": {"icon": "", "introduce": "", "jumpUrl": "", "preferredHr": false}, "todayInterview": null, "workLocation": {"address": "工作地点：拱墅区 · 上塘", "addressType": 0, "latitude": "30.322007", "longitude": "120.165431", "positionCityDistrict": "", "positionCityDistrictCode": "", "positionCityId": "653", "positionWorkCity": "", "showMap": true, "showMultiAddressesTip": "", "staticMapUrl": "https://storage-public.zhaopin.cn/job/share/1782108001339285021/49752220c7ca47448ff4fc72a4858e99", "streetName": "", "tradingArea": "", "travelMode": "bus", "verifyTheTruthUrl": "", "workAddress": "浙江省杭州市拱墅区沈半路198号"}}, "proxyWarning": null, "recommender": {"avatar": "", "name": "", "state": 0, "text": "", "title": ""}, "secure": {"abroadLabel": "", "abroadTipInfo": null, "safeCenter": null, "safetyReminder": null}, "staff": {"activityLevel": [], "auditNaturePrompt": null, "authenticationState": 0, "avatar": "https://storage-public.zhaopin.cn/zp/clouddisk/1771900457683718776/1cb61361-05a5-47ec-985a-488c8461e689.png?x-oss-process=image/